# ---- gateway-authorization-service: variáveis de ambiente ----
# Copie para .env e ajuste conforme necessário.

# ----- API Gateway (gateway/main.go) -----
GATEWAY_PORT=8080

# Origin do frontend permitido pelo middleware de CORS
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Keycloak usado para validar o access_token (RS256 via JWKS)
KEYCLOAK_URL=https://kiriland.unb.br/keycloak
KEYCLOAK_REALM=grupo03

# Endereços gRPC dos serviços downstream
AUTH_SERVICE_TARGET=localhost:50052
PATIENT_DATA_TARGET=localhost:50051
DATA_TRANSFORM_TARGET=localhost:50053

# ----- Authorization Service (auth_service/main.go) -----
AUTH_GRPC_PORT=50052
AUTH_METRICS_PORT=9091
# PATIENT_DATA_TARGET (acima) também é usado pelo Authorization Service
